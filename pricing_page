          </div>
          <div class="deliverable-item">
            <code>audit_defense_brief.md</code>
            <p>Auto-generated from schema annotations</p>
          </div>
        </div>
      </div>

      <!-- Timeline -->
      <div class="timeline reveal">
        <h3 class="section-title">The 21-Day Process</h3>
        <div class="timeline-grid">
          <div class="timeline-week">
            <div class="week-number">1</div>
            <div class="week-title">Schema Generation</div>
            <p class="week-desc">Your team generates baseline JSON schema for Article 12</p>
          </div>
          <div class="timeline-week">
            <div class="week-number">2</div>
            <div class="week-title">Validation & Refinement</div>
            <p class="week-desc">Iterate schema, add validation rules, generate log control policies</p>
          </div>
          <div class="timeline-week">
            <div class="week-number">3</div>
            <div class="week-title">CI/CD Integration</div>
            <p class="week-desc">Integrate into pipeline, generate Technical Files automatically</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-section">
    <h2 class="cta-title">Book Your Sprint</h2>
    <p class="cta-text">30-minute Architecture Jam to map your ADAS systems against Article 12/19 requirements. No deck. No sales pitch. Just architecture.</p>
    <a href="https://calendly.com/hello-keithan/calendly-com-keithan-audit-gap" class="cta-button" target="_blank">Book Architecture Jam →</a>
    <p class="cta-note">Or email: hello@keithan.eu</p>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-contact">
      <strong>LXD Advisory</strong> | EU AI Act Article 12/19 Compliance<br>
      <a href="mailto:hello@keithan.eu">hello@keithan.eu</a> | <a href="https://www.lxdadvisory.de" target="_blank">www.lxdadvisory.de</a>
    </div>
    <div class="footer-disclaimer">
      <strong>Disclaimer:</strong> LXD Advisory provides compliance methodology and technical implementation guidance. We are not a law firm and do not provide legal advice. For legal interpretation of EU AI Act requirements, consult qualified legal counsel. Services are provided "as is" without warranties of regulatory compliance outcomes.
    </div>
  </footer>
</div>

<script>
// Scroll reveal animation
const reveals = document.querySelectorAll('.reveal');
const revealOnScroll = () => {
  reveals.forEach(element => {
    const elementTop = element.getBoundingClientRect().top;
    const windowHeight = window.innerHeight;
    if (elementTop < windowHeight - 100) {
      element.classList.add('active');
    }
  });
};
window.addEventListener('scroll', revealOnScroll);
revealOnScroll(); // Initial check
</script>

</body>
</html>
